@page
@model EventBookingWeb.Pages.Bookings.IndexModel
@{
    ViewData["Title"] = "My Bookings";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold"><i class="bi bi-ticket-perforated me-2 text-primary"></i>My Bookings</h2>
    <a href="/Events" class="btn btn-outline-primary">
        <i class="bi bi-plus-circle me-1"></i>Book More
    </a>
</div>

<div id="loadingSpinner" class="text-center py-5">
    <div class="spinner-border text-primary" role="status"></div>
    <p class="mt-2 text-muted">Loading your bookings...</p>
</div>

<div id="errorAlert" class="alert alert-danger d-none"></div>
<div id="successAlert" class="alert alert-success d-none"></div>

<div id="noBookings" class="text-center py-5 d-none">
    <i class="bi bi-calendar-x text-muted" style="font-size:4rem;"></i>
    <h5 class="mt-3 text-muted">No bookings yet</h5>
    <a href="/Events" class="btn btn-primary mt-2">Browse Events</a>
</div>

<div id="bookingsContainer" class="d-none">
    <div class="table-responsive">
        <table class="table table-hover shadow-sm">
            <thead class="table-primary">
                <tr>
                    <th>#</th>
                    <th>Event</th>
                    <th>Location</th>
                    <th>Date</th>
                    <th>Seats</th>
                    <th>Booked On</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="bookingsTableBody"></tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
const API = 'http://localhost:5100';

document.addEventListener('DOMContentLoaded', () => {
    const token = localStorage.getItem('token');
    if (!token) { window.location.href = '/Auth/Login'; return; }
    loadBookings();
});

async function loadBookings() {
    const token = localStorage.getItem('token');
    try {
        const res = await fetch(`${API}/api/bookings`, {
            headers: { 'Authorization': `Bearer ${token}` }
        });
        if (res.status === 401) { window.location.href = '/Auth/Login'; return; }
        const bookings = await res.json();
        document.getElementById('loadingSpinner').classList.add('d-none');

        if (bookings.length === 0) {
            document.getElementById('noBookings').classList.remove('d-none');
            return;
        }

        document.getElementById('bookingsContainer').classList.remove('d-none');
        const tbody = document.getElementById('bookingsTableBody');
        tbody.innerHTML = bookings.map((b, i) => `
            <tr>
                <td>${i + 1}</td>
                <td><strong>${b.eventTitle}</strong></td>
                <td><i class="bi bi-geo-alt text-danger me-1"></i>${b.eventLocation}</td>
                <td>${new Date(b.eventDate).toLocaleDateString('en-IN')}</td>
                <td><span class="badge bg-success">${b.seatsBooked}</span></td>
                <td>${new Date(b.bookedAt).toLocaleDateString('en-IN')}</td>
                <td>
                    <button class="btn btn-sm btn-outline-danger" onclick="cancelBooking(${b.id}, '${b.eventTitle}')">
                        <i class="bi bi-x-circle me-1"></i>Cancel
                    </button>
                </td>
            </tr>
        `).join('');
    } catch {
        document.getElementById('loadingSpinner').classList.add('d-none');
        document.getElementById('errorAlert').textContent = 'Failed to load bookings.';
        document.getElementById('errorAlert').classList.remove('d-none');
    }
}

async function cancelBooking(id, title) {
    if (!confirm(`Cancel booking for "${title}"?`)) return;
    const token = localStorage.getItem('token');
    try {
        const res = await fetch(`${API}/api/bookings/${id}`, {
            method: 'DELETE',
            headers: { 'Authorization': `Bearer ${token}` }
        });
        const data = await res.json();
        if (res.ok) {
            document.getElementById('successAlert').textContent = data.message;
            document.getElementById('successAlert').classList.remove('d-none');
            setTimeout(() => document.getElementById('successAlert').classList.add('d-none'), 3000);
            loadBookings();
        } else {
            alert(data.message || 'Cancellation failed.');
        }
    } catch {
        alert('Connection error. Please try again.');
    }
}
</script>
}
